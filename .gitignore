###########################################################
# KiCad project files
###########################################################

# Auto-generated cache files
*.kicad_prl
*.kicad_pro-bak
*.kicad_sch-bak
*.kicad_pcb-bak
*-backups/

# Auto-save files
*_autosave-*.kicad_sch
*_autosave-*.kicad_pcb

# Lock files
*.lck

# Temporary files
*.tmp
*.bak
*.orig
*~

###########################################################
# KiCad generated fabrication outputs (regenerate anytime)
###########################################################

# Plot and fabrication outputs
*.gbr
*.gerber
*.drl
*.d356
*.rpt
*.pos
*.csv

# 3D export outputs
*.step
*.stp
*.wrl

# Drill files
*.drl
*.map

# Pick and place
*.pos
*.pnp

# BOM outputs
*.xml
*.csv

###########################################################
# KiCad local configuration (machine-specific)
###########################################################

# Local footprint/symbol cache
*-cache.lib
*-rescue.lib
*-cache.kicad_sym
*-rescue.kicad_sym

# Local preferences
sym-lib-table
fp-lib-table

###########################################################
# KiCad simulation artifacts
###########################################################

*.cir
*.spice
*.raw

###########################################################
# General OS clutter
###########################################################

.DS_Store
Thumbs.db
desktop.ini

###########################################################
# IDE/editor
###########################################################

.vscode/
.idea/
*.code-workspace

###########################################################
# Python (useful if scripts generate BOMs, etc.)
###########################################################

__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
dist/

###########################################################
# Firmware build outputs (PlatformIO / Arduino / CMake)
###########################################################

.pio/
build/
cmake-build-*/
*.elf
*.bin
*.hex
*.map

###########################################################
# Logs
###########################################################

*.log

###########################################################
# Archive exports
###########################################################

*.zip
*.tar
*.gz
